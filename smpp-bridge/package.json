{
  "name": "smpp-bridge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node --env-file=.env --import tsx/esm src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate --schema=../prisma/schema.prisma --generator=bridge"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bullmq": "^5.34.0",
    "hono": "^4.6.0",
    "ioredis": "^5.4.2",
    "p-retry": "^6.2.1",
    "pg": "^8.22.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "smpp": "0.5.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
