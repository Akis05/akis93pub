### 15.5 TanStack Query — Cache et état client

**Rôle :** cache des données, gestion loading/error, invalidation automatique après mutations.

**Pattern standard — hook de lecture :**
```ts
export const useVentesByStore = (storeId: string | undefined) => {
  return useQuery({
    queryKey: ["ventes", "store", storeId],   // clé de cache unique
    queryFn: async () => {
      if (!storeId) return [];
      const res = await client.api.ventes.store[":storeId"].$get({
        param: { storeId }, query: {},
      });
      if (!res.ok) throw new Error("Erreur récupération");
      const json = await res.json();
      return json.data?.rows ?? json.data;
    },
    enabled: !!storeId,   // ne s'exécute que si storeId est défini
  });
};
```

**Pattern standard — hook de mutation :**
```ts
export const useCreateVente = () => {
  const queryClient = useQueryClient();
  const mutation = useMutation({
    mutationFn: async (data) => {
      const res = await client.api.ventes.$post({ json: data });
      if (!res.ok) throw new Error(extractApiError(await res.json()));
      return res.json();
    },
    onSuccess: () => {
      // Invalide les caches concernés → re-fetch automatique
      queryClient.invalidateQueries({ queryKey: ["ventes"] });
      queryClient.invalidateQueries({ queryKey: ["stock"] });
      queryClient.invalidateQueries({ queryKey: ["dashboard"] });
    },
  });
  return mutation.mutateAsync; // exposé directement (pas l'objet mutation)
};
```

**Pagination infinie (`useInfinitePaginated`) :**
```ts
export const usePaginatedVentes = (storeId, limit = 50) => {
  return useInfinitePaginated<Vente>(
    ["ventes", "paginated", storeId, limit],
    async (page) => {
      const res = await client.api.ventes.store[":storeId"].$get({
        param: { storeId: storeId! },
        query: { page: String(page), limit: String(limit) },
      });
      const json = await res.json();
      return json.data; // { rows, total, page, pageSize, hasMore }
    },
    { enabled: !!storeId, pageSize: limit },
  );
};
// Retourne : { results, status, loadMore }
```

**Hiérarchie des queryKeys :**
```
["ventes"]                           → invalide tout le module ventes
["ventes", "store", storeId]         → liste paginée d'un store
["ventes", "stats", storeId]         → statistiques
["ventes", "detail", id]             → détail d'une vente
["ventes", "paginated", storeId, 50] → pagination infinie
```

